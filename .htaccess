# =============================================
# Mercería Larraz - Configuración Apache
# =============================================

# Bloquear acceso directo a directorios sensibles
<IfModule mod_rewrite.c>
    RewriteEngine On

    # Bloquear acceso a config/
    RewriteRule ^config/ - [F,L]

    # Bloquear acceso a lib/
    RewriteRule ^lib/ - [F,L]

    # Bloquear acceso a includes/
    RewriteRule ^includes/ - [F,L]

    # Bloquear acceso a archivos .env
    RewriteRule \.env$ - [F,L]
</IfModule>

# Bloquear listado de directorios
Options -Indexes

# Proteger archivos sensibles
<FilesMatch "\.(env|md|gitignore)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
</FilesMatch>

# Cabeceras de seguridad
<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "SAMEORIGIN"
    Header set X-XSS-Protection "1; mode=block"
</IfModule>

# Compresión GZIP
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css application/javascript image/svg+xml
</IfModule>

# Cache de archivos estáticos
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/jpeg "access plus 1 month"
    ExpiresByType image/png "access plus 1 month"
    ExpiresByType image/svg+xml "access plus 1 month"
    ExpiresByType text/css "access plus 1 week"
    ExpiresByType application/javascript "access plus 1 week"
</IfModule>
